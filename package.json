{
  "name": "digitshow-node",
  "version": "1.0.0",
  "description": "Node.js Modbus RTU CLI for soil testing",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "digitshow": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx --watch src/index.tsx --port /dev/ttyACM0 --config ds1.yaml",
    "start": "tsx src/index.tsx --port /dev/ttyACM0 --config ds1.yaml",
    "demo": "tsx src/demo.tsx",
    "build": "tsgo --noEmit",
    "test:watch": "vitest",
    "test": "vitest run --coverage",
    "check": "biome check --write ."
  },
  "keywords": [
    "modbus",
    "rtu",
    "soil",
    "testing",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "ink": "^6.7.0",
    "js-yaml": "^4.1.1",
    "modbus-serial": "^8.0.23",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "7.0.0-dev.20260217.1",
    "@vitest/coverage-v8": "^4.0.18",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18"
  }
}
